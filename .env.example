# ==============================================================================
# CONFIGURACIÓN GENERAL DEL ECOSISTEMA DE DEVOPS (12-FACTOR APP)
# Copy this file to '.env' and modify credentials as needed.
# ==============================================================================

# Entorno de Ejecución (production | development)
NODE_ENV=development

# ==============================================================================
# BASE DE DATOS (POSTGRESQL)
# ==============================================================================
# En docker-compose, el hostname es 'db'. En ejecución local directa es 'localhost'.
POSTGRES_USER=devops_user
POSTGRES_PASSWORD=devops_secure_password_99
POSTGRES_DB=devops_tasks_db
POSTGRES_PORT=5432

# URL de Conexión Completa para API y Worker
DATABASE_URL=postgresql://devops_user:devops_secure_password_99@db:5432/devops_tasks_db

# ==============================================================================
# BROKER / COLA DE MENSAJES (REDIS)
# ==============================================================================
# En docker-compose, el hostname es 'redis'. En ejecución local directa es 'localhost'.
REDIS_URL=redis://redis:6379

# ==============================================================================
# CONFIGURACIÓN DE PUERTOS INTERNOS Y MONITOREO
# ==============================================================================
PORT=5000
HEALTHCHECK_PORT=5001

# ==============================================================================
# FRONTEND CONFIGURACIONES (VITE)
# ==============================================================================
VITE_API_URL=http://localhost:5000
